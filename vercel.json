{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://tungbola.vercel.app https://*.vercel.app"
        }
      ]
    }
  ]
}
